# EAS Build ignore file
# This overrides .gitignore for EAS builds
# Files listed here will be EXCLUDED from the build

# Dependencies
node_modules/
node_modules
**/node_modules

# Expo
.expo/
.expo
dist/
web-build/

# Native (we let EAS generate these, but keep custom extensions/targets)
.kotlin/
*.orig.*

# Metro
.metro-health-check*

# debug / logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log
logs/

# macOS / Windows
.DS_Store
Thumbs.db
Desktop.ini

# typescript
*.tsbuildinfo

# temporary / cache
.npm-cache/
.npm-cache
**/.npm-cache
.cache/

# project specific large folders
backup/
scaf/
docs/
app-example/
app-example

# NOTE: We intentionally DO NOT ignore:
# - .env (needed for EXPO_PUBLIC_* variables)
# - google-services.json (needed for Android Google Sign-In)
# - GoogleService-Info.plist (needed for iOS Google Sign-In)
# - *.jks, *.p8, *.p12, *.key, *.mobileprovision (EAS manages these)
